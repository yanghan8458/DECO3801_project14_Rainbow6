// src/ai-agent/agent.js

const cognitiveAccessibilityAdvice = require("./skills/cognitiveAccessibilityPrompt");
const codeFixSuggestions           = require("./skills/codeFixSuggestions");

// -- Skill registry - add new skills here ----------------------------------
const skills = [
  cognitiveAccessibilityAdvice,   // inputType: "cognitive_accessibility_analysis"
  codeFixSuggestions              // inputType: "code_fix_request"
];

function getSkillByInputType(type) {
  return skills.find(skill => skill.inputType === type);
}

// -- Core agent runner -----------------------------------------------------

async function runAgent(input) {
  if (!input || typeof input !== "object") {
    return { ok: false, error: "Invalid agent input" };
  }

  const { type, payload } = input;

  if (!type) {
    return { ok: false, error: "Missing input type" };
  }

  const skill = getSkillByInputType(type);
  if (!skill) {
    return { ok: false, error: `No skill found for input type: ${type}` };
  }

  const result = await skill.run(payload || {});

  return {
    ok:        !result.error,
    agent:     "local-mini-ai-agent",
    skillUsed: skill.name,
    result
  };
}

